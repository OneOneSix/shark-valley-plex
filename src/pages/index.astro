<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shark Valley Plex</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #0a0a0f;
      color: #fff;
      font-family: system-ui, -apple-system, sans-serif;
      min-height: 100vh;
    }

    /* NAV */
    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 32px;
      border-bottom: 0.5px solid rgba(255,255,255,0.1);
    }

    .logo {
      font-size: 18px;
      font-weight: 500;
      color: #fff;
      letter-spacing: 0.02em;
      text-decoration: none;
    }

    .logo span { color: #1a8fff; }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 24px;
    }

    .nav-links a {
      font-size: 13px;
      color: rgba(255,255,255,0.65);
      text-decoration: none;
    }

    .nav-links a:hover { color: #fff; }

    .btn-request {
      background: #1a8fff;
      color: #fff !important;
      font-size: 13px;
      padding: 7px 16px;
      border-radius: 6px;
      text-decoration: none;
    }

    /* LOGO IMAGE */
    .logo-img {
      text-align: center;
      padding: 48px 32px 0;
    }

    .logo-img img {
      max-width: 200px;
      width: 100%;
      height: auto;
    }

    /* HERO */
    .hero {
      text-align: center;
      padding: 32px 32px 40px;
    }

    .hero h1 {
      font-size: 28px;
      font-weight: 500;
      color: #fff;
      margin-bottom: 12px;
      line-height: 1.3;
    }

    .hero p {
      font-size: 14px;
      color: rgba(255,255,255,0.55);
      max-width: 420px;
      margin: 0 auto;
      line-height: 1.7;
    }

    /* CARDS */
    .cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      padding: 8px 32px 40px;
      max-width: 860px;
      margin: 0 auto;
    }

    .card {
      background: #12121a;
      border: 0.5px solid rgba(255,255,255,0.1);
      border-radius: 14px;
      padding: 28px 24px;
      display: flex;
      flex-direction: column;
    }

    .card-icon {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 18px;
      font-size: 22px;
    }

    .card-icon.blue { background: rgba(26,143,255,0.15); }
    .card-icon.teal { background: rgba(29,158,117,0.15); }

    .card-icon i { font-size: 22px; }
    .card-icon.blue i { color: #1a8fff; }
    .card-icon.teal i { color: #1d9e75; }

    .card h2 {
      font-size: 17px;
      font-weight: 500;
      color: #fff;
      margin-bottom: 8px;
    }

    .card-desc {
      font-size: 13px;
      color: rgba(255,255,255,0.5);
      line-height: 1.6;
      margin-bottom: 20px;
      flex: 1;
    }

    .features {
      list-style: none;
      margin-bottom: 24px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .features li {
      font-size: 12px;
      color: rgba(255,255,255,0.55);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .features li i { font-size: 13px; }
    .features li i.blue { color: #1a8fff; }
    .features li i.teal { color: #1d9e75; }

    .btn-subscribe {
      display: block;
      text-align: center;
      padding: 10px 0;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 500;
      text-decoration: none;
      margin-top: auto;
    }

    .btn-subscribe.blue { background: #1a8fff; color: #fff; }
    .btn-subscribe.teal { background: #1d9e75; color: #fff; }

    /* FOOTER NOTE */
    .footer-note {
      text-align: center;
      padding: 0 32px 36px;
    }

    .footer-note p {
      font-size: 12px;
      color: rgba(255,255,255,0.35);
    }

    .footer-note a {
      color: rgba(255,255,255,0.55);
      text-decoration: underline;
    }

    /* FOOTER */
    .footer-bottom {
      text-align: center;
      padding: 20px 32px;
      border-top: 0.5px solid rgba(255,255,255,0.07);
    }

    .footer-bottom p {
      font-size: 11px;
      color: rgba(255,255,255,0.2);
    }

    /* MOBILE */
    @media (max-width: 640px) {
      nav { padding: 14px 16px; }
      .nav-links a:not(.btn-request) { display: none; }
      .btn-request { padding: 7px 14px; font-size: 13px; }
      .logo-img { padding: 32px 16px 0; }
      .hero { padding: 24px 16px 28px; }
      .hero h1 { font-size: 22px; }
      .cards { grid-template-columns: 1fr; padding: 8px 16px 40px; }
      .footer-note { padding: 0 16px 32px; }
      .footer-bottom { padding: 20px 16px; }
    }
  </style>
</head>
<body>

  <nav>
    <a class="logo" href="/">Shark Valley <span>Plex</span></a>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/faq">FAQ</a>
      <a href="https://stats.uptimerobot.com/9vb3fSvvMq" target="_blank" rel="noopener noreferrer">Status</a>
      <a class="btn-request" href="https://request.sharkvalleyplex.com" target="_blank" rel="noopener noreferrer">Request</a>
    </div>
  </nav>

  <div class="logo-img">
    <img src="/images/logo_stacked.svg" alt="Shark Valley Plex" />
  </div>

  <div class="hero">
    <h1>Your all-in-one streaming &amp; listening hub</h1>
    <p>Movies, TV shows, and audiobooks — all in one place. Subscribe to one or both services below.</p>
  </div>

  <div class="cards">

    <div class="card">
      <div class="card-icon blue">
        <i class="ti ti-device-tv" aria-hidden="true"></i>
      </div>
      <h2>Shark Valley Plex</h2>
      <p class="card-desc">Unlimited movies and TV shows, new titles added daily. Available on all smart devices.</p>
      <ul class="features">
        <li><i class="ti ti-check blue" aria-hidden="true"></i> Unlimited movies &amp; shows</li>
        <li><i class="ti ti-check blue" aria-hidden="true"></i> New titles added daily</li>
        <li><i class="ti ti-check blue" aria-hidden="true"></i> Request new content</li>
        <li><i class="ti ti-check blue" aria-hidden="true"></i> All smart devices</li>
      </ul>
      <a class="btn-subscribe blue" href="https://buy.stripe.com/eVq8wP16Fe3t8NWaGofjG01" rel="noopener noreferrer">Subscribe to Plex</a>
    </div>

    <div class="card">
      <div class="card-icon teal">
        <i class="ti ti-headphones" aria-hidden="true"></i>
      </div>
      <h2>Audiobooks</h2>
      <p class="card-desc">A growing library of audiobooks, available on demand. Listen anytime, anywhere.</p>
      <ul class="features">
        <li><i class="ti ti-check teal" aria-hidden="true"></i> Thousands of audiobooks</li>
        <li><i class="ti ti-check teal" aria-hidden="true"></i> New titles added regularly</li>
        <li><i class="ti ti-check teal" aria-hidden="true"></i> Request new titles</li>
        <li><i class="ti ti-check teal" aria-hidden="true"></i> All smart devices</li>
      </ul>
      <a class="btn-subscribe teal" href="YOUR_AUDIOBOOKS_STRIPE_LINK" rel="noopener noreferrer">Subscribe to Audiobooks</a>
    </div>

  </div>

  <div class="footer-note">
    <p>Already a member? <a href="https://billing.stripe.com/p/login/aFadR9g1z8J9c08eWEfjG00">Manage billing</a></p>
  </div>

  <div class="footer-bottom">
    <p>© 2026 Shark Valley Plex. All rights reserved.</p>
  </div>

</body>
</html>
