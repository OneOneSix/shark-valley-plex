---
import Layout from '../layouts/BlogPost.astro';
---

<Layout
  title="Shark Valley Plex"
  description="Your all-in-one streaming and listening hub."
>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" slot="head" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-size: 16px !important; line-height: 1.5 !important; background-color: #111827 !important; }
    main { width: 100% !important; max-width: 100% !important; padding: 0 !important; margin: 0 !important; }
    h1, h2, h3, h4, h5, h6 { font-size: unset; margin: 0; }
    p { margin-bottom: 0; }
    a { color: inherit; }
    img { border-radius: 0; }

    .logo-img {
      text-align: center;
      padding: 48px 24px 0;
    }

    .logo-img img {
      max-width: 200px;
      width: 100%;
      height: auto;
    }

    .page {
      max-width: 960px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .hero {
      text-align: center;
      padding: 32px 0 40px;
    }

    .hero h1 {
      font-size: 48px !important;
      font-weight: 800;
      line-height: 1.15;
      margin-bottom: 20px;
      color: #f9fafb;
      letter-spacing: -0.02em;
    }

    .hero h1 .gradient {
      display: block;
      background: linear-gradient(135deg, #6366f1, #a855f7);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero p {
      font-size: 15px;
      color: #9ca3af;
      line-height: 1.7;
      max-width: 420px;
      margin: 0 auto;
    }

    .cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      padding-bottom: 48px;
    }

    .card {
      background: #1f2937;
      border: 1px solid #374151;
      border-radius: 12px;
      padding: 28px 24px;
      display: flex;
      flex-direction: column;
    }

    .card:hover { border-color: #4b5563; }

    .card-icon {
      width: 46px;
      height: 46px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 18px;
    }

    .card-icon i { font-size: 24px; }
    .icon-indigo { background: rgba(99,102,241,0.15); }
    .icon-indigo i { color: #6366f1; }
    .icon-teal { background: rgba(20,184,166,0.15); }
    .icon-teal i { color: #14b8a6; }

    .card h2 {
      font-size: 17px !important;
      font-weight: 600;
      color: #f3f4f6;
      margin-bottom: 8px;
    }

    .card-desc {
      font-size: 13px;
      color: #6b7280;
      line-height: 1.6;
      margin-bottom: 18px;
      flex: 1;
    }

    .features {
      list-style: none;
      margin-bottom: 24px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .features li {
      font-size: 13px;
      color: #9ca3af;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .features li i { font-size: 14px; }
    .features li i.indigo { color: #6366f1; }
    .features li i.teal { color: #14b8a6; }

    .btn-sub {
      display: block;
      text-align: center;
      padding: 11px 0;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      margin-top: auto;
    }

    .btn-indigo { background: linear-gradient(135deg, #6366f1, #a855f7); color: #fff; }
    .btn-teal { background: linear-gradient(135deg, #14b8a6, #0ea5e9); color: #fff; }

    .footer-note {
      text-align: center;
      padding: 0 0 40px;
      font-size: 13px;
      color: #4b5563;
    }

    .footer-note a { color: #6b7280; text-decoration: underline; }
    .footer-note a:hover { color: #9ca3af; }

    @media (max-width: 640px) {
      .logo-img { padding: 32px 16px 0; }
      .page { padding: 0 16px; }
      .hero { padding: 24px 0 28px; }
      .hero h1 { font-size: 30px !important; }
      .cards { grid-template-columns: 1fr; }
      .footer-note { padding: 0 0 32px; }
    }
  </style>

  <div class="logo-img">
    <img src="/images/logo_stacked.svg" alt="Shark Valley Plex" />
  </div>

  <div class="page">
    <div class="hero">
      <h1>Your All-in-One<span class="gradient">Streaming &amp; Listening Hub</span></h1>
      <p>Movies, TV shows, and audiobooks — all in one place. Subscribe to one or both services below.</p>
    </div>

    <div class="cards">

      <div class="card">
        <div class="card-icon icon-indigo">
          <i class="ti ti-device-tv" aria-hidden="true"></i>
        </div>
        <h2>Shark Valley Plex</h2>
        <p class="card-desc">Movies and TV shows from all your favorite platforms. Watch anytime, anywhere.</p>
        <ul class="features">
          <li><i class="ti ti-check indigo" aria-hidden="true"></i> Unlimited Access to Movies and TV Shows</li>
          <li><i class="ti ti-check indigo" aria-hidden="true"></i> New Titles Added Daily</li>
          <li><i class="ti ti-check indigo" aria-hidden="true"></i> Request Movies and TV Shows</li>
          <li><i class="ti ti-check indigo" aria-hidden="true"></i> Available on All Smart Devices</li>
        </ul>
        <a class="btn-sub btn-indigo" href="https://buy.stripe.com/eVq8wP16Fe3t8NWaGofjG01" rel="noopener noreferrer">Subscribe to Plex</a>
      </div>

      <div class="card">
        <div class="card-icon icon-teal">
          <i class="ti ti-headphones" aria-hidden="true"></i>
        </div>
        <h2>Audiobooks</h2>
        <p class="card-desc">A curated library of audiobooks across every genre. Listen anytime, anywhere.</p>
        <ul class="features">
          <li><i class="ti ti-check teal" aria-hidden="true"></i> Unlimited Access to Audiobooks</li>
          <li><i class="ti ti-check teal" aria-hidden="true"></i> New Titles Added Daily</li>
          <li><i class="ti ti-check teal" aria-hidden="true"></i> Request Audiobooks</li>
          <li><i class="ti ti-check teal" aria-hidden="true"></i> Available on All Smart Devices</li>
        </ul>
        <a class="btn-sub btn-teal" href="YOUR_AUDIOBOOKS_STRIPE_LINK" rel="noopener noreferrer">Subscribe to Audiobooks</a>
      </div>

    </div>

    <div class="footer-note">
      Already a member? <a href="https://billing.stripe.com/p/login/aFadR9g1z8J9c08eWEfjG00">Manage billing</a>
    </div>
  </div>

</Layout>
