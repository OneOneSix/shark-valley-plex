  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background-color: #111827;
      color: #fff;
      font-family: system-ui, -apple-system, sans-serif;
      min-height: 100vh;
    }

    /* NAV */
    nav {
      background-color: #1f2937;
      border-bottom: 1px solid #374151;
      padding: 0 24px;
      height: 64px;
      display: flex;
      align-items: center;
    }

    .nav-inner {
      width: 100%;
      max-width: 960px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      text-decoration: none;
      flex-shrink: 0;
    }


    .nav-links {
      display: flex;
      align-items: center;
      flex: 1;
      justify-content: space-evenly;
    }

    .nav-links a {
      font-size: 16px;
      color: #9ca3af;
      text-decoration: none;
      padding: 8px 14px;
      border-radius: 6px;
      white-space: nowrap;
    }

    .nav-links a:hover {
      background: #374151;
      color: #fff;
    }

    .nav-links a.active {
      color: #fff;
      border-bottom: 4px solid #6366f1;
      border-radius: 0;
      background: none;
      padding-bottom: 4px;
    }

    .btn-request {
      background: linear-gradient(135deg, #6366f1, #a855f7);
      color: #fff !important;
      padding: 8px 18px;
      border-radius: 6px;
      font-size: 16px;
      font-weight: 500;
      text-decoration: none;
      white-space: nowrap;
    }

    /* STATS */
    .stats {
      display: flex;
      justify-content: center;
      gap: 48px;
      padding: 32px 24px 0;
    }

    .stat {
      text-align: center;
    }

    .stat-number {
      font-size: 32px;
      font-weight: 800;
      color: #f9fafb;
      letter-spacing: -0.02em;
      line-height: 1;
      margin-bottom: 4px;
    }

    .stat-label {
      font-size: 13px;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* LOGO IMAGE */
    .logo-img {
      text-align: center;
      padding: 48px 24px 0;
    }

    .logo-img img {
      max-width: 350px;
      width: 100%;
      height: auto;
    }

    /* PAGE */
    .page {
      max-width: 960px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* HERO */
    .hero {
      text-align: center;
      padding: 32px 0 40px;
    }

    .hero h1 {
      font-size: 48px;
      font-weight: 800;
      line-height: 1.15;
      margin-bottom: 20px;
      color: #f9fafb;
      letter-spacing: -0.02em;
    }

    .hero h1 .gradient {
      display: block;
      background: linear-gradient(135deg, #6366f1, #a855f7);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero p {
      font-size: 15px;
      color: #9ca3af;
      line-height: 1.7;
      max-width: 350px;
      margin: 0 auto;
    }

    /* CARDS */
    .cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      padding-bottom: 48px;
    }

    .card {
      background: #1f2937;
      border: 1px solid #374151;
      border-radius: 12px;
      padding: 28px 24px;
      display: flex;
      flex-direction: column;
    }

    .card:hover { border-color: #4b5563; }

    .card-icon {
      width: 46px;
      height: 46px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 18px;
    }

    .card-icon i { font-size: 24px; }

    .icon-indigo { background: rgba(99,102,241,0.15); }
    .icon-indigo i { color: #6366f1; }

    .icon-teal { background: rgba(20,184,166,0.15); }
    .icon-teal i { color: #14b8a6; }

    .card h2 {
      font-size: 17px;
      font-weight: 600;
      color: #f3f4f6;
      margin-bottom: 8px;
    }

    .card-desc {
      font-size: 13px;
      color: #6b7280;
      line-height: 1.6;
      margin-bottom: 18px;
      flex: 1;
    }

    .features {
      list-style: none;
      margin-bottom: 24px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .features li {
      font-size: 13px;
      color: #9ca3af;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .features li i { font-size: 14px; }
    .features li i.indigo { color: #6366f1; }
    .features li i.teal { color: #14b8a6; }

    .btn-sub {
      display: block;
      text-align: center;
      padding: 11px 0;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      margin-top: auto;
    }

    .btn-indigo {
      background: linear-gradient(135deg, #6366f1, #a855f7);
      color: #fff;
    }

    .btn-teal {
      background: linear-gradient(135deg, #14b8a6, #0ea5e9);
      color: #fff;
    }

    /* FOOTER NOTE */
    .footer-note {
      text-align: center;
      padding: 0 0 40px;
      font-size: 13px;
      color: #4b5563;
    }

    .footer-note a {
      color: #6b7280;
      text-decoration: underline;
    }

    .footer-note a:hover { color: #9ca3af; }

    /* FOOTER */
    footer {
      background: #1f2937;
      border-top: 1px solid #374151;
      text-align: center;
      padding: 20px;
      font-size: 12px;
      color: #4b5563;
    }

    /* MOBILE */
    @media (max-width: 640px) {
      nav { padding: 0 16px; height: 56px; }
      .stats { gap: 24px; padding: 24px 16px 0; }
      .stat-number { font-size: 24px; }
      .nav-links { gap: 2px; }
      .nav-links a { font-size: 14px; padding: 8px 10px; }
      .btn-request { padding: 7px 14px; font-size: 14px; }
      .logo-img { padding: 32px 16px 0; }
      .page { padding: 0 16px; }
      .hero { padding: 24px 0 28px; }
      .hero h1 { font-size: 30px; }
      .cards { grid-template-columns: 1fr; }
      .footer-note { padding: 0 0 32px; }
    }
  </style>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const statEls = document.querySelectorAll('.stat-number');

      function animateCounter(el) {
        const text = el.textContent.trim();
        const suffix = text.replace(/[\d,]/g, '');
        const target = parseInt(text.replace(/[^0-9]/g, ''), 10);
        const duration = 3000;
        const startTime = performance.now();

        function easeOutQuart(t) {
          return 1 - Math.pow(1 - t, 4);
        }

        function update(currentTime) {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const eased = easeOutQuart(progress);
          const current = Math.floor(eased * target);
          el.textContent = current.toLocaleString() + suffix;
          if (progress < 1) {
            requestAnimationFrame(update);
          } else {
            el.textContent = target.toLocaleString() + suffix;
          }
        }

        requestAnimationFrame(update);
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            animateCounter(entry.target);
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      statEls.forEach(el => {
        const rect = el.getBoundingClientRect();
        const inView = rect.top < window.innerHeight && rect.bottom > 0;
        if (inView) {
          animateCounter(el);
        } else {
          observer.observe(el);
        }
      });
    });
  </script>
  <style>@view-transition { navigation: auto; }</style>
