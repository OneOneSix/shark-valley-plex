<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shark Valley Plex</title>
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: #111827;
      color: #fff;
      font-family: system-ui, -apple-system, sans-serif;
      min-height: 100vh;
    }

    /* NAV */
    nav {
      background-color: #1f2937;
      border-bottom: 1px solid #374151;
      padding: 0 24px;
      height: 64px;
      display: flex;
      align-items: center;
    }

    .nav-inner {
      width: 100%;
      max-width: 960px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo {
      font-size: 17px;
      font-weight: 600;
      color: #fff;
      text-decoration: none;
      white-space: nowrap;
    }

    .nav-logo span {
      background: linear-gradient(135deg, #6366f1, #a855f7);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .nav-links a {
      font-size: 14px;
      color: #9ca3af;
      text-decoration: none;
      padding: 6px 12px;
      border-radius: 6px;
    }

    .nav-links a:hover {
      background: #374151;
      color: #fff;
    }

    .btn-request {
      background: linear-gradient(135deg, #6366f1, #a855f7);
      color: #fff !important;
      padding: 7px 16px;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
    }

    /* PAGE WRAPPER */
    .page {
      max-width: 960px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* HERO */
    .hero {
      text-align: center;
      padding: 64px 0 40px;
    }

    .hero h1 {
      font-size: 32px;
      font-weight: 700;
      line-height: 1.3;
      margin-bottom: 14px;
      color: #f9fafb;
    }

    .hero p {
      font-size: 15px;
      color: #9ca3af;
      line-height: 1.7;
      max-width: 420px;
      margin: 0 auto;
    }

    /* CARDS */
    .cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      padding-bottom: 48px;
    }

    .card {
      background: #1f2937;
      border: 1px solid #374151;
      border-radius: 12px;
      padding: 28px 24px;
      display: flex;
      flex-direction: column;
    }

    .card-icon {
      width: 46px;
      height: 46px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      margin-bottom: 18px;
    }

    .icon-indigo { background: rgba(99,102,241,0.15); }
    .icon-teal   { background: rgba(20,184,166,0.15); }

    .card h2 {
      font-size: 17px;
      font-weight: 600;
      color: #f3f4f6;
      margin-bottom: 8px;
    }

    .card-desc {
      font-size: 13px;
      color: #6b7280;
      line-height: 1.6;
      margin-bottom: 18px;
      flex: 1;
    }

    .features {
      list-style: none;
      margin-bottom: 24px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .features li {
      font-size: 13px;
      color: #9ca3af;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .features li img {
      width: 14px;
      height: 14px;
      flex-shrink: 0;
    }

    .btn-sub {
      display: block;
      text-align: center;
      padding: 11px 0;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      margin-top: auto;
    }

    .btn-indigo {
      background: linear-gradient(135deg, #6366f1, #a855f7);
      color: #fff;
    }

    .btn-teal {
      background: linear-gradient(135deg, #14b8a6, #0ea5e9);
      color: #fff;
    }

    /* FOOTER NOTE */
    .footer-note {
      text-align: center;
      padding: 0 0 40px;
      font-size: 13px;
      color: #4b5563;
    }

    .footer-note a {
      color: #6b7280;
      text-decoration: underline;
    }

    /* FOOTER */
    footer {
      background: #1f2937;
      border-top: 1px solid #374151;
      text-align: center;
      padding: 20px;
      font-size: 12px;
      color: #4b5563;
    }

    /* MOBILE */
    @media (max-width: 640px) {
      nav {
        padding: 0 16px;
        height: 56px;
      }
      .nav-links a:not(.btn-request) {
        display: none;
      }
      .btn-request {
        padding: 7px 14px;
        font-size: 13px;
      }
      .page {
        padding: 0 16px;
      }
      .hero {
        padding: 40px 0 28px;
      }
      .hero h1 {
        font-size: 24px;
      }
      .cards {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>

  <nav>
    <div class="nav-inner">
      <a class="nav-logo" href="/">Shark Valley <span>Plex</span></a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/faq">FAQ</a>
        <a href="https://stats.uptimerobot.com/9vb3fSvvMq" target="_blank" rel="noopener noreferrer">Status</a>
        <a class="btn-request" href="https://request.sharkvalleyplex.com" target="_blank" rel="noopener noreferrer">Request</a>
      </div>
    </div>
  </nav>

  <main class="page">

    <div style="text-align: center; padding-top: 48px;">
      <img src="/images/logo_stacked.svg" alt="Shark Valley Plex" style="max-width: 350px; width: 100%; height: auto;" />
    </div>

    <div class="hero" style="padding-top: 24px;">
      <h1>Your all-in-one streaming &amp; listening hub</h1>
      <p>Movies, TV shows, and audiobooks — all in one place. Subscribe to one or both services below.</p>
    </div>

    <div class="cards">

      <div class="card">
        <div class="card-icon icon-indigo">🎬</div>
        <h2>Shark Valley Plex</h2>
        <p class="card-desc">Unlimited movies and TV shows, new titles added daily. Available on all smart devices.</p>
        <ul class="features">
          <li><img src="/images/emoji_image.png" alt="" />Unlimited movies &amp; shows</li>
          <li><img src="/images/emoji_image.png" alt="" />New titles added daily</li>
          <li><img src="/images/emoji_image.png" alt="" />Request new content</li>
          <li><img src="/images/emoji_image.png" alt="" />All smart devices</li>
        </ul>
        <a class="btn-sub btn-indigo" href="https://buy.stripe.com/eVq8wP16Fe3t8NWaGofjG01" rel="noopener noreferrer">
          Subscribe to Plex
        </a>
      </div>

      <div class="card">
        <div class="card-icon icon-teal">🎧</div>
        <h2>Audiobooks</h2>
        <p class="card-desc">A growing library of audiobooks, available on demand. Listen anytime, anywhere.</p>
        <ul class="features">
          <li><img src="/images/emoji_image.png" alt="" />Thousands of audiobooks</li>
          <li><img src="/images/emoji_image.png" alt="" />New titles added regularly</li>
          <li><img src="/images/emoji_image.png" alt="" />Request new titles</li>
          <li><img src="/images/emoji_image.png" alt="" />All smart devices</li>
        </ul>
        <a class="btn-sub btn-teal" href="YOUR_AUDIOBOOKS_STRIPE_LINK" rel="noopener noreferrer">
          Subscribe to Audiobooks
        </a>
      </div>

    </div>

    <div class="footer-note">
      Already a member? <a href="https://billing.stripe.com/p/login/aFadR9g1z8J9c08eWEfjG00">Manage billing</a>
    </div>

  </main>

  <footer>
    <p>© 2026 Shark Valley Plex. All rights reserved.</p>
  </footer>

</body>
</html>
